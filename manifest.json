{
  "manifest_version": 3,
  "name": "Live Noodmelder",
  "version": "6.0",
  "key": "",
  "permissions": ["alarms", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}