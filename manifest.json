{
  "manifest_version": 3,
  "name": "Live Noodmelder",
  "version": "9.0",
  "description": "Ontvang live noodmeldingen op je Chromebook.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
